NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000
TZ=Asia/Jakarta

# JWT (wajib diganti di production)
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kehadiran

# Redis (queue worker otomatis jalan saat npm run dev)
REDIS_URL=redis://localhost:6379
QUEUE_ENABLED=true

# CORS — comma-separated (production / origin khusus)
# Development: IP LAN (192.168.x.x) otomatis diizinkan oleh app.ts
# Production: https://fe-kehadiran.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3010

# MinIO / S3-compatible
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=kehadiran
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

OWNER_LICENSE_TOKEN=ubah-ke-token-lisensi-anda

# Bypass manual absensi BioFinger → POST /api/v1/dev/attendance/ingest (opsional di dev)
MANUAL_INGEST_TOKEN=dev-manual-ingest

# Password default akun karyawan auto-create dari BioFinger (login: NIK + password ini)
DEFAULT_EMPLOYEE_PASSWORD=password123

# Telegram — Listener mode: auto | bot | polling | user | none
# auto (default) = deteksi otomatis dari credential yang tersedia
# bot = MTProto bot listener (butuh API_ID + API_HASH + BOT_TOKEN)
# polling = Bot API long-polling (butuh BOT_TOKEN saja)
# user = MTProto user listener (butuh API_ID + API_HASH + USER_SESSION)
# none = nonaktifkan semua listener
TELEGRAM_LISTENER_MODE=auto

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=ubah-ke-string-random-panjang
TELEGRAM_ALLOWED_GROUP_IDS=
TELEGRAM_MONITOR_BOT_USERNAME=manjursehatkehadiran_bot

# MTProto — api_id & api_hash dari https://my.telegram.org
# Semua listener otomatis jalan saat `npm run dev` / `npm start`
# Tidak perlu terminal terpisah lagi untuk telegram:biofinger
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BIOFINGER_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=
TELEGRAM_DEFAULT_BRANCH_ID=
TELEGRAM_MONITOR_GROUP_ID=
# Session string dari `npm run telegram:user-login` (untuk TELEGRAM_LISTENER_MODE=user)
TELEGRAM_USER_SESSION=

# ⚠️ PRODUCTION SETTINGS DI RAILWAY:
# PORT=8080 (BUKAN 8000! — Dockerfile expose 8080)
# NODE_ENV=production
# CORS_ORIGINS=https://fe-kehadiran.vercel.app
# JWT_SECRET=<ganti-ke-random-string-panjang>
# DATABASE_URL=<database-connection-string>
# REDIS_URL=<redis-connection-string>

# BioFinger ADMS / HTTP push (opsional, jika mesin support)
ADMS_PORT=7792
BIOFINGER_WEBHOOK_SECRET=
STAFF_XLS_PATH=
