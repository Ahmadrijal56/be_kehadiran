NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000
TZ=Asia/Jakarta

# JWT (wajib diganti di production)
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kehadiran

# Redis
REDIS_URL=redis://localhost:6379

# CORS (frontend dev)
CORS_ORIGINS=http://localhost:3000,http://10.180.141.142:3000

# MinIO / S3-compatible (Fase berikutnya)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=kehadiran
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Telegram — Bio Finger APT MANJUR SEHAT TSI
TELEGRAM_BOT_TOKEN=8978820140:AAFSEfK6RsSL8rIQrus2Gck6nuLqu00xphU
TELEGRAM_WEBHOOK_SECRET=dev-secret-manjursehat-2026
# Chat pribadi bot (bukan grup) — isi setelah npm run telegram:get-chat-id
TELEGRAM_BIOFINGER_CHAT_ID=
# Kosong = semua chat diizinkan
TELEGRAM_ALLOWED_GROUP_IDS=
# Token lisensi registrasi owner pertama (halaman login)
OWNER_LICENSE_TOKEN=08816175344

# Queue (false = proses absensi langsung tanpa Redis worker)
QUEUE_ENABLED=true
DEFAULT_EMPLOYEE_PASSWORD=password123

# MTProto — api_id & api_hash dari https://my.telegram.org + Bot Token
# TIDAK perlu login HP. Jalankan: npm run telegram:biofinger
TELEGRAM_API_ID=35741048
TELEGRAM_API_HASH=d5ec1df3dc24f768dda0f622685f2bda
TELEGRAM_MONITOR_BOT_USERNAME=manjursehatkehadiran_bot

# Server ADMS Bio Finger (TANPA login Telegram) — port 7792
ADMS_PORT=7792

# Bio Finger HTTP push — TANPA chat_id Telegram
