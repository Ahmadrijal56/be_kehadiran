{
  "name": "kehadiran-api",
  "version": "0.1.0",
  "private": true,
  "description": "Sistem Manajemen Kehadiran & KPI — REST API (Node.js)",
  "type": "module",
  "scripts": {
    "predev": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "auth:reset-password": "tsx scripts/reset-password.ts",
    "queue:work": "tsx src/worker.ts",
    "scheduler": "tsx src/scheduler.ts",
    "kpi:calculate-monthly-ranks": "tsx src/cli/calculateMonthlyRanks.ts",
    "create:branch": "tsx src/cli/createBranch.ts",
    "create:owner-account": "tsx src/cli/createOwnerAccount.ts",
    "create:manager-account": "tsx src/cli/createManagerAccount.ts",
    "create:employee-account": "tsx src/cli/createEmployeeAccount.ts",
    "telegram:set-webhook": "tsx scripts/set-telegram-webhook.ts",
    "telegram:get-chat-id": "tsx scripts/telegram-get-chat-id.ts",
    "telegram:user-login": "tsx scripts/telegram-user-login.ts",
    "telegram:bot-listen": "tsx src/telegramBotListener.ts",
    "telegram:biofinger": "tsx src/telegramBotListener.ts",
    "telegram:poll": "tsx src/telegramListener.ts",
    "telegram:listen": "tsx src/telegramListener.ts",
    "telegram:user-listen": "tsx src/telegramUserListener.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "@aws-sdk/s3-request-presigner": "^3.1060.0",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.78.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "sharp": "^0.35.1",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "bcrypt": "^6.0.0",
    "eslint": "^9.17.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
