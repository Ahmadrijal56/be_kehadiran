# Salin ke .env.avatar-test lalu sesuaikan:
#   cp .env.avatar-test.example .env.avatar-test
#
# Load test upload foto profil — 20 akun, 1 gambar sumber (>500 KB), hasil kompres server ≤200 KB.

# URL API (tanpa /api/v1)
AVATAR_TEST_API_BASE=http://localhost:8000

# Password sama untuk semua akun uji (DEFAULT_EMPLOYEE_PASSWORD di .env utama)
AVATAR_TEST_PASSWORD=password123

# 20 NIK karyawan — harus sudah ada di database (total 20 upload)
AVATAR_TEST_NIKS=100001,100002,100003,100004,100005,100006,100007,100008,100009,100010,100011,100012,100013,100014,100015,100016,100017,100018,100019,100020

# Gambar sumber (>500 KB). Kosongkan → script buat otomatis di path ini.
AVATAR_TEST_SOURCE_IMAGE=scripts/fixtures/avatar-test-source.jpg

# Ukuran minimum file sumber (byte) — tim QA: rata-rata di atas 500 KB
AVATAR_TEST_MIN_SOURCE_BYTES=512000
