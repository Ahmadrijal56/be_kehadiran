generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id                     String                @id @default(uuid()) @db.Uuid
  code                   String                @unique @db.VarChar(20)
  name                   String                @db.VarChar(150)
  address                String?
  telegramGroupId        BigInt?               @map("telegram_group_id")
  timezone               String                @default("Asia/Jakarta") @db.VarChar(50)
  isActive               Boolean               @default(true) @map("is_active")
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  /// false = cabang hanya absen masuk & pulang (tanpa istirahat)
  breakAttendanceEnabled Boolean               @default(true) @map("break_attendance_enabled")
  announcements          Announcement[]
  attendanceRecords      AttendanceRecord[]
  branchShifts           BranchShift[]
  employeeTypes          EmployeeTypeConfig[]
  employees              Employee[]
  kpiMonthlyAggregates   KpiMonthlyAggregate[]
  userBranches           UserBranch[]
  users                  User[]

  @@map("branches")
}

model Shift {
  id                Int                @id @db.SmallInt
  code              String             @unique @db.VarChar(10)
  name              String             @db.VarChar(50)
  startTime         DateTime           @map("start_time") @db.Time(6)
  endTime           DateTime           @map("end_time") @db.Time(6)
  attendanceRecords AttendanceRecord[]
  branchShifts      BranchShift[]
  employeeShifts    EmployeeShift[]
  employees         Employee[]

  @@map("shifts")
}

/// Jam & aktivasi shift per cabang (S1 TSI 07–15 vs S1 PIK 08–16).
model BranchShift {
  branchId  String   @map("branch_id") @db.Uuid
  shiftId   Int      @map("shift_id") @db.SmallInt
  isActive  Boolean  @default(true) @map("is_active")
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)
  /// Label kode per cabang (null = pakai shifts.code).
  code      String?  @db.VarChar(10)
  /// Label nama per cabang (null = pakai shifts.name).
  name      String?  @db.VarChar(50)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift     Shift    @relation(fields: [shiftId], references: [id])

  @@id([branchId, shiftId])
  @@map("branch_shifts")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(50)
  name            String           @db.VarChar(100)
  description     String?
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(100)
  module          String           @db.VarChar(50)
  description     String?
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model EmployeeTypeConfig {
  code                   String     @db.VarChar(8)
  label                  String     @db.VarChar(100)
  shiftIds               Int[]      @map("shift_ids")
  sortOrder              Int        @default(0) @map("sort_order")
  isActive               Boolean    @default(true) @map("is_active")
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  breakAttendanceEnabled Boolean    @default(true) @map("break_attendance_enabled")
  id                     String     @id @default(uuid()) @db.Uuid
  branchId               String     @map("branch_id") @db.Uuid
  managerFeaturesEnabled Boolean    @default(false) @map("manager_features_enabled")
  branch                 Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees              Employee[]

  @@unique([branchId, code])
  @@index([branchId], map: "idx_employee_type_configs_branch")
  @@map("employee_type_configs")
}

model Employee {
  id                            String                      @id @default(uuid()) @db.Uuid
  nik                           String                      @db.VarChar(32)
  fullName                      String                      @map("full_name") @db.VarChar(150)
  branchId                      String                      @map("branch_id") @db.Uuid
  defaultShiftId                Int                         @map("default_shift_id") @db.SmallInt
  hireDate                      DateTime?                   @map("hire_date") @db.Date
  isActive                      Boolean                     @default(true) @map("is_active")
  employeeTypeCode              String?                     @map("employee_type_code") @db.VarChar(8)
  accountCode                   String?                     @map("account_code") @db.VarChar(20)
  shiftScheduleAssigned         Boolean                     @default(true) @map("shift_schedule_assigned")
  achievements                  Achievement[]
  shiftSwapCounterpartyRequests AttendanceApprovalRequest[] @relation("ShiftSwapCounterparty")
  attendanceApprovalRequests    AttendanceApprovalRequest[]
  attendanceRecords             AttendanceRecord[]
  employeeShifts                EmployeeShift[]
  employeeType                  EmployeeTypeConfig?         @relation(fields: [branchId, employeeTypeCode], references: [branchId, code])
  branch                        Branch                      @relation(fields: [branchId], references: [id])
  defaultShift                  Shift                       @relation(fields: [defaultShiftId], references: [id])
  kpiDailyScores                KpiDailyScore[]
  kpiMonthlyAggregates          KpiMonthlyAggregate[]
  lateExcuses                   LateExcuse[]
  managerEvaluations            ManagerEvaluation[]
  user                          User?

  @@unique([branchId, nik], map: "employees_branch_nik_key")
  @@index([branchId], map: "idx_employees_branch")
  @@index([nik], map: "idx_employees_nik")
  @@index([accountCode], map: "idx_employees_account_code")
  @@map("employees")
}

model User {
  id                   String                      @id @default(uuid()) @db.Uuid
  email                String?                     @unique @db.VarChar(255)
  nik                  String                      @unique @db.VarChar(32)
  passwordHash         String                      @map("password_hash") @db.VarChar(255)
  fullName             String                      @map("full_name") @db.VarChar(150)
  phone                String?                     @db.VarChar(20)
  branchId             String?                     @map("branch_id") @db.Uuid
  employeeId           String?                     @unique @map("employee_id") @db.Uuid
  isActive             Boolean                     @default(true) @map("is_active")
  lastLoginAt          DateTime?                   @map("last_login_at") @db.Timestamptz(6)
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  accountCode          String?                     @unique @map("account_code") @db.VarChar(20)
  avatarUrl            String?                     @map("avatar_url") @db.VarChar(512)
  avatarVisibility     AvatarVisibility            @default(branch) @map("avatar_visibility")
  announcementReads    AnnouncementRead[]
  announcementsCreated Announcement[]
  attachmentsUploaded  Attachment[]
  approvalsReviewed    AttendanceApprovalRequest[] @relation("ApprovalReviewedBy")
  auditLogs            AuditLog[]
  lateExcusesReviewed  LateExcuse[]                @relation("ReviewedBy")
  managerEvaluations   ManagerEvaluation[]         @relation("ManagerUser")
  notifications        Notification[]
  push_subscriptions   push_subscriptions[]
  rewardsIssued        Reward[]                    @relation("IssuedBy")
  userBranches         UserBranch[]
  userRoles            UserRole[]
  branch               Branch?                     @relation(fields: [branchId], references: [id])
  employee             Employee?                   @relation(fields: [employeeId], references: [id])

  @@index([branchId], map: "idx_users_branch")
  @@index([nik], map: "idx_users_nik")
  @@index([isActive], map: "idx_users_active")
  @@map("users")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserBranch {
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId], map: "idx_user_branches_branch")
  @@map("user_branches")
}

model EmployeeShift {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  workDate   DateTime @map("work_date") @db.Date
  shiftId    Int      @map("shift_id") @db.SmallInt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift      Shift    @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, workDate])
  @@map("employee_shifts")
}

model TelegramMessage {
  id                String             @id @default(uuid()) @db.Uuid
  telegramMessageId BigInt             @map("telegram_message_id")
  telegramGroupId   BigInt             @map("telegram_group_id")
  rawText           String             @map("raw_text")
  parsedJson        Json?              @map("parsed_json")
  photoFileId       String?            @map("photo_file_id") @db.VarChar(255)
  deviceId          String?            @map("device_id") @db.VarChar(100)
  syncStatus        TelegramSyncStatus @default(pending) @map("sync_status")
  errorMessage      String?            @map("error_message")
  attendanceId      String?            @unique @map("attendance_id") @db.Uuid
  receivedAt        DateTime           @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt       DateTime?          @map("processed_at") @db.Timestamptz(6)
  sourcedAttendance AttendanceRecord?  @relation("SourceMessage")
  linkedAttendance  AttendanceRecord?  @relation("MessageAttendance", fields: [attendanceId], references: [id])

  @@unique([telegramGroupId, telegramMessageId], map: "telegram_messages_group_message_key")
  @@index([syncStatus], map: "idx_tg_status")
  @@map("telegram_messages")
}

model AttendanceRecord {
  id               String                      @id @default(uuid()) @db.Uuid
  employeeId       String                      @map("employee_id") @db.Uuid
  branchId         String                      @map("branch_id") @db.Uuid
  workDate         DateTime                    @map("work_date") @db.Date
  shiftId          Int                         @map("shift_id") @db.SmallInt
  checkInAt        DateTime?                   @map("check_in_at") @db.Timestamptz(6)
  checkOutAt       DateTime?                   @map("check_out_at") @db.Timestamptz(6)
  attendanceType   AttendanceType?             @map("attendance_type")
  sourceMessageId  String?                     @unique @map("source_message_id") @db.Uuid
  photoUrl         String?                     @map("photo_url") @db.VarChar(500)
  deviceId         String?                     @map("device_id") @db.VarChar(100)
  lateMinutes      Int                         @default(0) @map("late_minutes")
  status           AttendanceStatus            @default(absent)
  checkOutIsAuto   Boolean                     @default(false) @map("check_out_is_auto")
  approvalRequests AttendanceApprovalRequest[]
  branch           Branch                      @relation(fields: [branchId], references: [id])
  employee         Employee                    @relation(fields: [employeeId], references: [id])
  shift            Shift                       @relation(fields: [shiftId], references: [id])
  sourceMessage    TelegramMessage?            @relation("SourceMessage", fields: [sourceMessageId], references: [id])
  breakSessions    BreakSession[]
  kpiDailyScore    KpiDailyScore?
  lateExcuses      LateExcuse[]
  linkedMessage    TelegramMessage?            @relation("MessageAttendance")

  @@unique([employeeId, workDate], map: "attendance_records_employee_work_date_key")
  @@index([branchId, workDate], map: "idx_att_branch_date")
  @@index([employeeId, workDate], map: "idx_att_employee_date")
  @@index([status], map: "idx_att_status")
  @@map("attendance_records")
}

model BreakSession {
  id              String           @id @default(uuid()) @db.Uuid
  attendanceId    String           @map("attendance_id") @db.Uuid
  breakStartAt    DateTime         @map("break_start_at") @db.Timestamptz(6)
  breakEndAt      DateTime?        @map("break_end_at") @db.Timestamptz(6)
  durationMinutes Int?             @map("duration_minutes")
  attendance      AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("break_sessions")
}

model KpiDailyScore {
  id               String           @id @default(uuid()) @db.Uuid
  employeeId       String           @map("employee_id") @db.Uuid
  workDate         DateTime         @map("work_date") @db.Date
  checkInPoints    Int              @map("check_in_points") @db.SmallInt
  adjustmentPoints Int              @default(0) @map("adjustment_points") @db.SmallInt
  totalPoints      Int              @map("total_points") @db.SmallInt
  lateMinutes      Int              @map("late_minutes")
  ruleApplied      String           @map("rule_applied") @db.VarChar(50)
  employee         Employee         @relation(fields: [employeeId], references: [id])
  attendance       AttendanceRecord @relation(fields: [employeeId, workDate], references: [employeeId, workDate])

  @@unique([employeeId, workDate], map: "kpi_daily_scores_employee_work_date_key")
  @@map("kpi_daily_scores")
}

model KpiMonthlyAggregate {
  id               String   @id @default(uuid()) @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  branchId         String   @map("branch_id") @db.Uuid
  yearMonth        String   @map("year_month") @db.Char(7)
  totalPoints      Int      @map("total_points")
  totalLateCount   Int      @default(0) @map("total_late_count")
  totalPresentDays Int      @default(0) @map("total_present_days")
  rankBranch       Int?     @map("rank_branch")
  rankGlobal       Int?     @map("rank_global")
  branch           Branch   @relation(fields: [branchId], references: [id])
  employee         Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, yearMonth], map: "kpi_monthly_aggregates_employee_month_key")
  @@map("kpi_monthly_aggregates")
}

model LateExcuse {
  id           String           @id @default(uuid()) @db.Uuid
  attendanceId String           @map("attendance_id") @db.Uuid
  employeeId   String           @map("employee_id") @db.Uuid
  reasonText   String           @map("reason_text")
  status       LateExcuseStatus @default(pending)
  managerNote  String?          @map("manager_note")
  reviewedById String?          @map("reviewed_by") @db.Uuid
  reviewedAt   DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  attendance   AttendanceRecord @relation(fields: [attendanceId], references: [id])
  employee     Employee         @relation(fields: [employeeId], references: [id])
  reviewedBy   User?            @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@map("late_excuses")
}

model AttendanceApprovalRequest {
  id                     String                   @id @default(uuid()) @db.Uuid
  employeeId             String                   @map("employee_id") @db.Uuid
  branchId               String                   @map("branch_id") @db.Uuid
  workDate               DateTime                 @map("work_date") @db.Date
  type                   AttendanceApprovalType
  reasonText             String                   @map("reason_text")
  status                 AttendanceApprovalStatus @default(pending)
  managerNote            String?                  @map("manager_note")
  reviewedById           String?                  @map("reviewed_by") @db.Uuid
  reviewedAt             DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  attendanceId           String?                  @map("attendance_id") @db.Uuid
  requestedShiftId       Int?                     @map("requested_shift_id") @db.SmallInt
  shiftConfirmedAt       DateTime?                @map("shift_confirmed_at") @db.Timestamptz(6)
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  counterpartyEmployeeId String?                  @map("counterparty_employee_id") @db.Uuid
  peerRespondedAt        DateTime?                @map("peer_responded_at") @db.Timestamptz(6)
  peerStatus             ShiftSwapPeerStatus?     @map("peer_status")
  requesterShiftId       Int?                     @map("requester_shift_id") @db.SmallInt
  attendance             AttendanceRecord?        @relation(fields: [attendanceId], references: [id])
  counterparty           Employee?                @relation("ShiftSwapCounterparty", fields: [counterpartyEmployeeId], references: [id])
  employee               Employee                 @relation(fields: [employeeId], references: [id])
  reviewedBy             User?                    @relation("ApprovalReviewedBy", fields: [reviewedById], references: [id])

  @@index([branchId, status], map: "idx_approval_branch_status")
  @@index([employeeId, workDate], map: "idx_approval_employee_date")
  @@map("attendance_approval_requests")
}

model Attachment {
  id         String @id @default(uuid()) @db.Uuid
  entityType String @map("entity_type") @db.VarChar(50)
  entityId   String @map("entity_id") @db.Uuid
  filePath   String @map("file_path") @db.VarChar(500)
  mimeType   String @map("mime_type") @db.VarChar(100)
  sizeBytes  Int    @map("size_bytes")
  uploadedBy String @map("uploaded_by") @db.Uuid
  uploader   User   @relation(fields: [uploadedBy], references: [id])

  @@index([entityType, entityId], map: "idx_attachments_entity")
  @@map("attachments")
}

model KpiPointRule {
  id               String   @id @default(uuid()) @db.Uuid
  points           Int
  minOffsetSeconds Int      @map("min_offset_seconds")
  maxOffsetSeconds Int?     @map("max_offset_seconds")
  label            String   @db.VarChar(200)
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("kpi_point_rules")
}

model GamificationSettings {
  id                            String    @id @default("default") @db.VarChar(32)
  lateThresholdSeconds          Int       @default(1) @map("late_threshold_seconds")
  monthlyRewardsEnabled         Boolean   @default(true) @map("monthly_rewards_enabled")
  top1AmountIdr                 Int       @default(100000) @map("top1_amount_idr")
  top1RewardLabel               String    @default("Voucher Indomaret") @map("top1_reward_label") @db.VarChar(150)
  top2AmountIdr                 Int       @default(50000) @map("top2_amount_idr")
  top2RewardLabel               String    @default("Voucher Indomaret") @map("top2_reward_label") @db.VarChar(150)
  top3AmountIdr                 Int       @default(25000) @map("top3_amount_idr")
  top3RewardLabel               String    @default("Voucher Indomaret") @map("top3_reward_label") @db.VarChar(150)
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  ownerRegistrationToken        String?   @map("owner_registration_token") @db.VarChar(128)
  orgWideRankingEnabled         Boolean   @default(false) @map("org_wide_ranking_enabled")
  employeeLiveAttendanceEnabled Boolean   @default(false) @map("employee_live_attendance_enabled")
  /// Tanggal mulai KPI kehadiran operasional (WIB). Null = otomatis dari data pertama.
  attendanceKpiStartDate        DateTime? @map("attendance_kpi_start_date") @db.Date
  pwaEnabled                    Boolean   @default(true) @map("pwa_enabled")
  pwaPushEnabled                Boolean   @default(true) @map("pwa_push_enabled")

  @@map("gamification_settings")
}

model Achievement {
  id             String           @id @default(uuid()) @db.Uuid
  employeeId     String           @map("employee_id") @db.Uuid
  type           AchievementType
  scope          AchievementScope
  yearMonth      String           @map("year_month") @db.Char(7)
  pointsSnapshot Int              @map("points_snapshot")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  employee       Employee         @relation(fields: [employeeId], references: [id])
  rewards        Reward[]

  @@map("achievements")
}

model Reward {
  id            String       @id @default(uuid()) @db.Uuid
  achievementId String       @map("achievement_id") @db.Uuid
  rewardType    String       @default("voucher") @map("reward_type") @db.VarChar(50)
  amountIdr     Int          @map("amount_idr")
  status        RewardStatus @default(pending)
  issuedAt      DateTime?    @map("issued_at") @db.Timestamptz(6)
  issuedById    String?      @map("issued_by") @db.Uuid
  achievement   Achievement  @relation(fields: [achievementId], references: [id])
  issuedBy      User?        @relation("IssuedBy", fields: [issuedById], references: [id])

  @@map("rewards")
}

model Announcement {
  id          String             @id @default(uuid()) @db.Uuid
  title       String             @db.VarChar(200)
  body        String
  scope       AnnouncementScope
  branchId    String?            @map("branch_id") @db.Uuid
  createdById String             @map("created_by") @db.Uuid
  publishedAt DateTime           @map("published_at") @db.Timestamptz(6)
  expiresAt   DateTime?          @map("expires_at") @db.Timestamptz(6)
  reads       AnnouncementRead[]
  branch      Branch?            @relation(fields: [branchId], references: [id])
  createdBy   User               @relation(fields: [createdById], references: [id])

  @@map("announcements")
}

model AnnouncementRead {
  userId         String       @map("user_id") @db.Uuid
  announcementId String       @map("announcement_id") @db.Uuid
  readAt         DateTime     @default(now()) @map("read_at") @db.Timestamptz(6)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, announcementId])
  @@index([userId], map: "idx_announcement_reads_user")
  @@map("announcement_reads")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(200)
  body      String
  dataJson  Json?     @map("data_json")
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], map: "idx_notif_user_unread")
  @@map("notifications")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([userId, createdAt], map: "idx_audit_user_time")
  @@map("audit_logs")
}

model ManagerEvaluation {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  managerId   String   @map("manager_id") @db.Uuid
  note        String
  bonusPoints Int      @default(0) @map("bonus_points")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  employee    Employee @relation(fields: [employeeId], references: [id])
  manager     User     @relation("ManagerUser", fields: [managerId], references: [id])

  @@map("manager_evaluations")
}

/// * Binary upload persisten (avatar, lampiran) — fallback PostgreSQL saat R2/volume tidak ada.
model StoredBlob {
  objectKey String   @id @map("object_key") @db.VarChar(512)
  data      Bytes
  mimeType  String   @map("mime_type") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("stored_blobs")
}

model push_subscriptions {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  endpoint   String
  p256dh     String
  auth       String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @db.Timestamptz(6)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, endpoint])
  @@index([user_id], map: "idx_push_subscriptions_user")
}

